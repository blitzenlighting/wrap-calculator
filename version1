<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Column Wrap Light Strand Calculator</title>
  <style>
    :root { --gap: 14px; --radius: 14px; --shadow: 0 6px 18px rgba(0,0,0,.08); }
    * { box-sizing: border-box; font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji"; }
    body { margin: 0; background: #0b1220; color: #f6f7fb; display: grid; place-items: start center; min-height: 100svh; padding: 24px; }
    .card { width: min(920px, 100%); background: #121a2b; border: 1px solid rgba(255,255,255,.06); border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; }
    header { padding: 20px 22px; border-bottom: 1px solid rgba(255,255,255,.08); display: flex; justify-content: space-between; align-items: center; gap: var(--gap); }
    header h1 { margin: 0; font-size: clamp(18px, 2.4vw, 24px); letter-spacing: .3px; }
    header p { margin: 0; opacity: .8; font-size: 14px; }
    .grid { display: grid; gap: var(--gap); grid-template-columns: repeat(12, 1fr); padding: 22px; }
    .field { grid-column: span 12; display: grid; gap: 8px; }
    .field.half { grid-column: span 6; }
    .field.third { grid-column: span 4; }
    label { font-size: 13px; opacity: .9; }
    input, select { width: 100%; padding: 12px 12px; border-radius: 10px; border: 1px solid rgba(255,255,255,.12); background: #0e1524; color: #f6f7fb; outline: none; }
    input[readonly] { opacity: .8; }
    input::placeholder { color: rgba(255,255,255,.45); }
    .row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap); }
    .actions { display: flex; gap: 10px; flex-wrap: wrap; }
    button { appearance: none; padding: 12px 16px; border-radius: 12px; border: 0; font-weight: 600; cursor: pointer; }
    .primary { background: #3b82f6; color: white; }
    .secondary { background: #19223a; color: #e8ecf8; border: 1px solid rgba(255,255,255,.08); }
    .results { background: #0e1524; border-top: 1px solid rgba(255,255,255,.08); padding: 18px 22px; display: grid; gap: 12px; }
    .kpis { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; }
    .kpi { background: #121a2b; border: 1px solid rgba(255,255,255,.08); border-radius: 12px; padding: 14px; }
    .kpi b { display: block; font-size: 13px; opacity: .75; margin-bottom: 6px; }
    .kpi span { font-size: 22px; font-weight: 700; }
    .note { font-size: 12px; opacity: .75; }
    .hidden { display: none; }
    @media (max-width: 860px) { .field.half { grid-column: span 12; } .field.third { grid-column: span 12; } .kpis { grid-template-columns: 1fr 1fr; } }
  </style>
</head>
<body>
  <div class="card" role="application" aria-label="Column Wrap Light Strand Calculator">
    <header>
      <div>
        <h1>Column Wrap Light Strand Calculator</h1>
        <p>Pick round or square, enter size and height. Spacing and strand length are fixed: 4 in spacing, 23 ft strands.</p>
      </div>
    </header>

    <div class="grid">
      <div class="field third">
        <label for="shape">Column shape</label>
        <select id="shape">
          <option value="round">Round</option>
          <option value="square">Square</option>
        </select>
      </div>

      <div class="field third" id="diameterField">
        <label for="diameter">Diameter (inches)</label>
        <input id="diameter" type="number" min="1" step="0.01" placeholder="e.g. 12" />
      </div>

      <div class="field third hidden" id="sideField">
        <label for="side">Side width for square column (inches)</label>
        <input id="side" type="number" min="1" step="0.01" placeholder="e.g. 10" />
      </div>

      <div class="field third">
        <label for="height">Column wrap height to cover (feet)</label>
        <input id="height" type="number" min="0.1" step="0.01" placeholder="e.g. 11" />
      </div>

      <div class="field third">
        <label>Vertical spacing (inches)</label>
        <input value="4" readonly />
      </div>

      <div class="field third">
        <label>Strand length (feet)</label>
        <input value="23" readonly />
      </div>

      <div class="field" style="grid-column: span 12;">
        <div class="actions">
          <button class="primary" id="calcBtn">Calculate</button>
          <button class="secondary" id="resetBtn" type="button">Reset</button>
        </div>
      </div>
    </div>

    <div class="results" id="results" aria-live="polite">
      <div class="kpis">
        <div class="kpi"><b>Total light length</b><span id="totalLen">0 ft</span></div>
        <div class="kpi"><b>Estimated wraps</b><span id="wraps">0</span></div>
        <div class="kpi"><b>Length per wrap</b><span id="wrapLen">0 ft</span></div>
        <div class="kpi"><b>Strands needed</b><span id="strands">0</span></div>
      </div>
      <div class="note" id="details"></div>
      <div class="note" id="example"></div>
    </div>
  </div>

  <script>
    const $ = (id) => document.getElementById(id);

    const shape = $("shape");
    const diameterField = $("diameterField");
    const sideField = $("sideField");

    shape.addEventListener("change", () => {
      const isRound = shape.value === "round";
      diameterField.classList.toggle("hidden", !isRound);
      sideField.classList.toggle("hidden", isRound);
    });

    function feet(n) { return `${n.toFixed(2)} ft`; }

    function calc() {
      const isRound = shape.value === "round";
      const diameterIn = parseFloat($("diameter").value || "0");
      const sideIn = parseFloat($("side").value || "0");
      const heightFt = parseFloat($("height").value || "0");

      // Fixed values per request
      const spacingIn = 4; // inches
      const strandFt = 23; // feet

      if (heightFt <= 0 || (!isRound && sideIn <= 0) || (isRound && diameterIn <= 0)) {
        alert("Enter positive numbers for height and size.");
        return;
      }

      const spacingFt = spacingIn / 12;
      const perimeterFt = isRound ? Math.PI * (diameterIn / 12) : 4 * (sideIn / 12);

      const wraps = heightFt / spacingFt; // number of helical passes
      const lengthPerWrap = Math.sqrt(perimeterFt ** 2 + spacingFt ** 2);
      const total = lengthPerWrap * wraps;

      const exactStrands = total / strandFt;
      const strandsNeeded = Math.ceil(exactStrands); // always round up

      $("totalLen").textContent = feet(total);
      $("wraps").textContent = wraps.toFixed(1);
      $("wrapLen").textContent = feet(lengthPerWrap);
      $("strands").textContent = `${exactStrands.toFixed(2)} or ${strandsNeeded}`;

      const detailText = `Perimeter ${feet(perimeterFt)}, spacing ${feet(spacingFt)}. Exact strands = total length ÷ 23 ft. Always use the rounded-up value for ordering.`;
      $("details").textContent = detailText;

      // Example from the prompt if values match: round, 11 ft, 21 in
      const exampleNote = (isRound && Math.abs(heightFt - 11) < 1e-9 && Math.abs(diameterIn - 21) < 1e-9)
        ? `Example check: 11 ft high, 21 in diameter yields ${exactStrands.toFixed(2)} or ${strandsNeeded} strands.`
        : ``;
      $("example").textContent = exampleNote;
    }

    $("calcBtn").addEventListener("click", calc);
    $("resetBtn").addEventListener("click", () => { 
      document.querySelectorAll("input[type='number']").forEach(i => i.value = ""); 
      $("shape").value = "round"; 
      shape.dispatchEvent(new Event("change")); 
      $("totalLen").textContent = "0 ft"; 
      $("wraps").textContent = "0"; 
      $("wrapLen").textContent = "0 ft"; 
      $("strands").textContent = "0"; 
      $("details").textContent = ""; 
      $("example").textContent = "";
    });

    // sensible defaults for fast testing
    $("diameter").value = 21;
    $("height").value = 11;
  </script>
</body>
</html>
